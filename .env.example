# Database Connection
DATABASE_URL="prisma+postgres://localhost:51213/?api_key=your-prisma-accelerate-api-key"
DIRECT_DATABASE_URL="postgres://postgres:postgres@localhost:5432/postgres?sslmode=disable"
SHADOW_DATABASE_URL="postgres://postgres:postgres@localhost:5433/postgres?sslmode=disable"

# Auth
JWT_SECRET="replace-with-a-long-random-secret"

# Public app URL used in newsletter links
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# SMTP (Gmail SMTP supported)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="your-account@gmail.com"
SMTP_PASS="your-app-password"
MAIL_FROM="MAC TECH <your-account@gmail.com>"
CONTACT_NOTIFY_TO="hello@mance.dev"

# Campaign delivery controls
MAIL_BATCH_SIZE="25"
MAIL_RETRY_ATTEMPTS="3"
MAIL_INITIAL_BACKOFF_MS="300"

# Supabase (for file storage)
SUPABASE_SECRET_KEY="sb_secret_your-secret"
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="sb_publishable_your-publishable-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

